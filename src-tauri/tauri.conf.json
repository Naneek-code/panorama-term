{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Panorama",
  "version": "0.1.0",
  "identifier": "com.frenvius.panorama",
  "build": {
    "beforeDevCommand": "bun run ui:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run ui:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Panorama",
        "width": 1280,
        "height": 820,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
